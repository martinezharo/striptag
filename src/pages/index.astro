---
// Tag and attribute checkboxes are generated client-side from whatever the
// pasted HTML actually contains (see the script below), so nothing is rendered
// statically here.
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>StripTag — strip your HTML down to the essentials</title>
    <meta
      name="description"
      content="Clean pasted HTML right in your browser: peel off the tags and attributes you don't want. 100% client-side — nothing leaves your machine."
    />
  </head>
  <body>
    <div class="flex min-h-dvh flex-col lg:h-dvh lg:overflow-hidden">
      <!-- ───────────── Top bar ───────────── -->
      <header
        class="flex flex-wrap items-center justify-between gap-x-6 gap-y-2 border-b border-border-soft px-5 py-3"
      >
        <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
          <h1
            class="m-0 text-xl font-bold tracking-tight"
            aria-label="StripTag"
          >
            <span class="font-mono font-bold" aria-hidden="true"
              ><span class="text-blue">&lt;</span><span
                class="slash animate-tease inline-block text-accent [text-shadow:0_0_12px_var(--color-accent)]"
                style="transform-origin:50% 55%">/</span
              ><span class="text-blue">&gt;</span></span
            ><span class="ml-2">Strip<span class="text-accent">Tag</span></span>
          </h1>
          <p class="m-0 text-[13px] text-muted">
            We undress your markup down to exactly what you want.
          </p>
        </div>

        <span
          class="inline-flex items-center gap-1.5 rounded-full border border-border-soft bg-surface px-2.5 py-1 text-[11px] font-medium text-muted"
          title="Everything runs locally in your browser. No uploads, ever."
        >
          <svg
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-ok"
            aria-hidden="true"
          >
            <rect x="3" y="11" width="18" height="11" rx="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
          100% client-side · what happens here, stays here
        </span>
      </header>

      <main
        class="grid min-h-0 flex-1 grid-cols-1 gap-3 p-3 auto-rows-[minmax(300px,auto)] lg:auto-rows-[minmax(0,1fr)] lg:grid-cols-[1fr_360px_1fr] lg:overflow-hidden"
      >
        <!-- ───────────── Left: source input ───────────── -->
        <section class="panel input-panel">
          <div class="panel-head">
            <span class="panel-title">
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <polyline points="16 18 22 12 16 6"></polyline>
                <polyline points="8 6 2 12 8 18"></polyline>
              </svg>
              Source HTML
            </span>
            <button id="load-sample" class="ghost-btn" type="button">
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M12 3v18M3 12h18"></path>
              </svg>
              Load sample
            </button>
          </div>
          <textarea
            id="input"
            class="code-area"
            spellcheck="false"
            placeholder="Paste your messy HTML here and watch it lose a few layers…"
          ></textarea>
        </section>

        <!-- ───────────── Middle: controls ───────────── -->
        <section class="panel controls-panel">
          <div class="panel-head">
            <span class="panel-title">
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path
                  d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"
                ></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
              Options
            </span>
          </div>

          <div class="controls-scroll min-h-0 flex-1 space-y-3 overflow-y-auto p-3">
            <!-- Mode -->
            <fieldset class="ctrl-group">
              <legend class="ctrl-legend">Mode</legend>
              <div
                class="segmented w-full"
                role="radiogroup"
                aria-label="Cleaning mode"
              >
                <label class="seg flex-1">
                  <input type="radio" name="mode" value="blacklist" checked />
                  <span class="text-center">Blacklist</span>
                </label>
                <label class="seg flex-1">
                  <input type="radio" name="mode" value="whitelist" />
                  <span class="text-center">Whitelist</span>
                </label>
              </div>
              <p id="mode-caption" class="caption">
                Stripping off the tags &amp; attributes you pick.
              </p>
            </fieldset>

            <!-- Removed-tag behaviour -->
            <fieldset class="ctrl-group">
              <legend class="ctrl-legend">When a tag comes off</legend>
              <div
                class="segmented w-full"
                role="radiogroup"
                aria-label="Tag removal behaviour"
              >
                <label class="seg flex-1">
                  <input type="radio" name="removal" value="unwrap" checked />
                  <span class="text-center">Unwrap</span>
                </label>
                <label class="seg flex-1">
                  <input type="radio" name="removal" value="remove" />
                  <span class="text-center">Remove contents</span>
                </label>
              </div>
              <p class="caption">
                Unwrap keeps the inner content; Remove deletes the whole element.
              </p>
            </fieldset>

            <!-- Comments -->
            <fieldset class="ctrl-group">
              <legend class="ctrl-legend">Comments</legend>
              <label class="switch">
                <input type="checkbox" id="keep-comments" />
                <span class="track" aria-hidden="true"></span>
                <span>Keep HTML comments</span>
              </label>
              <p class="caption">
                <code>&lt;script&gt;</code>, <code>&lt;style&gt;</code> and
                <code>&lt;noscript&gt;</code> always come off, contents and all.
              </p>
            </fieldset>

            <!-- Tags (auto-detected from the pasted HTML) -->
            <fieldset class="ctrl-group">
              <legend class="ctrl-legend">
                Tags found
                <span
                  id="tag-count"
                  class="rounded-full bg-inset px-1.5 py-0.5 font-mono text-[10px] text-blue"
                  >0</span
                >
              </legend>
              <div class="mb-2.5 flex gap-2">
                <button class="ghost-btn" type="button" data-all="tags"
                  >Select all</button
                >
                <button class="ghost-btn" type="button" data-clear="tags"
                  >Clear</button
                >
              </div>
              <div class="checkbox-grid" id="tag-grid"></div>
            </fieldset>

            <!-- Attributes (auto-detected from the pasted HTML) -->
            <fieldset class="ctrl-group">
              <legend class="ctrl-legend">
                Attributes found
                <span
                  id="attr-count"
                  class="rounded-full bg-inset px-1.5 py-0.5 font-mono text-[10px] text-blue"
                  >0</span
                >
              </legend>
              <div class="mb-2.5 flex gap-2">
                <button class="ghost-btn" type="button" data-all="attrs"
                  >Select all</button
                >
                <button class="ghost-btn" type="button" data-clear="attrs"
                  >Clear</button
                >
              </div>
              <div class="checkbox-grid" id="attr-grid"></div>
            </fieldset>
          </div>
        </section>

        <!-- ───────────── Right: output ───────────── -->
        <section class="panel output-panel">
          <div class="panel-head">
            <div
              class="segmented"
              role="radiogroup"
              aria-label="Output view"
            >
              <label class="seg">
                <input type="radio" name="view" value="preview" checked />
                <span>Preview</span>
              </label>
              <label class="seg">
                <input type="radio" name="view" value="code" />
                <span>Code</span>
              </label>
            </div>
            <button id="copy-btn" class="primary-btn" type="button">
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                ></path>
              </svg>
              <span id="copy-label">Copy</span>
            </button>
          </div>

          <div class="output-body flex min-h-0 flex-1">
            <iframe
              id="preview"
              class="preview-frame w-full flex-1 border-0 bg-white"
              sandbox=""
              title="Cleaned HTML preview"></iframe>
            <pre
              id="code-view"
              class="code-area code-out"
              hidden><code></code></pre>
          </div>
        </section>
      </main>

      <footer
        class="flex flex-wrap items-center justify-end gap-2 px-5 py-2.5 text-[11px] text-faint"
      >
        <a
          href="https://github.com/martinezharo/striptag"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 transition-colors hover:text-text"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58 0-.29-.01-1.04-.02-2.05-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.21.09 1.84 1.24 1.84 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.34-5.47-5.95 0-1.31.47-2.39 1.24-3.23-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6.01 0c2.29-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.92 1.23 3.23 0 4.62-2.81 5.64-5.49 5.94.43.37.82 1.1.82 2.22 0 1.61-.02 2.9-.02 3.29 0 .32.22.7.83.58A12.01 12.01 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z"
            ></path>
          </svg>
          martinezharo/striptag
        </a>
      </footer>
    </div>

    <script>
      import { cleanHtml, defaultOptions, extractTagsAndAttrs, type CleanOptions } from '../lib/cleaner';
      import { formatHtml } from '../lib/format';

      // ── Element handles ────────────────────────────────────────────────
      const $ = <T extends Element = HTMLElement>(sel: string) =>
        document.querySelector(sel) as T;

      const input = $<HTMLTextAreaElement>('#input');
      const keepComments = $<HTMLInputElement>('#keep-comments');
      const modeCaption = $('#mode-caption');
      const tagGrid = $('#tag-grid');
      const attrGrid = $('#attr-grid');
      const tagCount = $('#tag-count');
      const attrCount = $('#attr-count');
      const preview = $<HTMLIFrameElement>('#preview');
      const codeView = $<HTMLPreElement>('#code-view');
      const codeEl = codeView.querySelector('code') as HTMLElement;
      const copyBtn = $<HTMLButtonElement>('#copy-btn');
      const copyLabel = $('#copy-label');

      const radioValue = (name: string) =>
        ($(`input[name="${name}"]:checked`) as HTMLInputElement).value;

      // ── Selection state (kept in memory so it survives re-detection) ────
      // A name stays selected even if it briefly disappears from the input.
      const selectedTags = new Set<string>();
      const selectedAttrs = new Set<string>();
      // Currently-detected lists, for the Select all / Clear helpers.
      let detectedTags: string[] = [];
      let detectedAttrs: string[] = [];

      // ── Build a checkbox grid from a detected list ─────────────────────
      function buildGrid(container: Element, items: string[], set: Set<string>) {
        container.replaceChildren();
        if (items.length === 0) {
          const empty = document.createElement('p');
          empty.className = 'empty';
          empty.textContent = 'Nothing to strip yet…';
          container.append(empty);
          return;
        }
        for (const item of items) {
          const label = document.createElement('label');
          label.className = 'check';
          const cb = document.createElement('input');
          cb.type = 'checkbox';
          cb.value = item;
          cb.checked = set.has(item);
          cb.addEventListener('change', () => {
            if (cb.checked) set.add(item);
            else set.delete(item);
            applyAndOutput();
          });
          const span = document.createElement('span');
          span.textContent = item;
          label.append(cb, span);
          container.append(label);
        }
      }

      // ── Re-detect tags/attrs from the input, rebuilding grids on change ─
      let lastTagKey = '';
      let lastAttrKey = '';
      function refreshDetected() {
        const { tags, attrs } = extractTagsAndAttrs(input.value);
        tagCount.textContent = String(tags.length);
        attrCount.textContent = String(attrs.length);
        const tagKey = tags.join(',');
        const attrKey = attrs.join(',');
        if (tagKey !== lastTagKey) {
          detectedTags = tags;
          buildGrid(tagGrid, tags, selectedTags);
          lastTagKey = tagKey;
        }
        if (attrKey !== lastAttrKey) {
          detectedAttrs = attrs;
          buildGrid(attrGrid, attrs, selectedAttrs);
          lastAttrKey = attrKey;
        }
      }

      // ── Clean + render output ──────────────────────────────────────────
      let lastCode = '';
      let formatSeq = 0; // guards against out-of-order async formatting

      function readOptions(): CleanOptions {
        const opts = defaultOptions();
        opts.mode = radioValue('mode') as CleanOptions['mode'];
        opts.tagRemoval = radioValue('removal') as CleanOptions['tagRemoval'];
        opts.keepComments = keepComments.checked;
        opts.tags = new Set(selectedTags);
        opts.attrs = new Set(selectedAttrs);
        return opts;
      }

      async function applyAndOutput() {
        lastCode = cleanHtml(input.value, readOptions());

        // Preview is sandboxed (empty sandbox attr → no script execution).
        preview.srcdoc = lastCode;

        // Code view: pretty-print asynchronously, ignoring stale results.
        const seq = ++formatSeq;
        const pretty = await formatHtml(lastCode);
        if (seq === formatSeq) codeEl.textContent = pretty;
      }

      // Full pass: re-detect controls, then clean. Used on input changes.
      function render() {
        refreshDetected();
        applyAndOutput();
      }

      function updateModeCaption() {
        modeCaption.textContent =
          radioValue('mode') === 'blacklist'
            ? 'Stripping off the tags & attributes you pick.'
            : 'Keeping only what you pick — the rest comes off.';
      }

      // ── Debounced input, immediate everything-else ─────────────────────
      let debounceId: number | undefined;
      input.addEventListener('input', () => {
        window.clearTimeout(debounceId);
        debounceId = window.setTimeout(render, 250);
      });

      keepComments.addEventListener('change', applyAndOutput);
      document.querySelectorAll('input[name="removal"]').forEach((el) =>
        el.addEventListener('change', applyAndOutput),
      );
      document.querySelectorAll('input[name="mode"]').forEach((el) =>
        el.addEventListener('change', () => {
          updateModeCaption();
          applyAndOutput();
        }),
      );

      // ── View toggle (Preview / Code) ───────────────────────────────────
      document.querySelectorAll<HTMLInputElement>('input[name="view"]').forEach((el) =>
        el.addEventListener('change', () => {
          const code = radioValue('view') === 'code';
          codeView.hidden = !code;
          preview.hidden = code;
        }),
      );

      // ── Select all / Clear helpers (act on currently-detected items) ───
      function setGroup(group: string, on: boolean) {
        const [items, set, grid] =
          group === 'tags'
            ? ([detectedTags, selectedTags, tagGrid] as const)
            : ([detectedAttrs, selectedAttrs, attrGrid] as const);
        for (const item of items) {
          if (on) set.add(item);
          else set.delete(item);
        }
        buildGrid(grid, items, set);
        applyAndOutput();
      }
      document.querySelectorAll<HTMLButtonElement>('[data-all]').forEach((btn) =>
        btn.addEventListener('click', () => setGroup(btn.dataset.all!, true)),
      );
      document.querySelectorAll<HTMLButtonElement>('[data-clear]').forEach((btn) =>
        btn.addEventListener('click', () => setGroup(btn.dataset.clear!, false)),
      );

      // ── Copy (copies the code string, not the rendered DOM) ────────────
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(lastCode);
          copyLabel.textContent = 'Copied 😏';
          copyBtn.classList.add('ok');
          window.setTimeout(() => {
            copyLabel.textContent = 'Copy';
            copyBtn.classList.remove('ok');
          }, 1200);
        } catch {
          copyLabel.textContent = 'Copy failed';
          window.setTimeout(() => (copyLabel.textContent = 'Copy'), 1200);
        }
      });

      // ── Sample loader + initial paint ──────────────────────────────────
      // Split the closing script tag so it can't terminate this inline block.
      const SAMPLE = `<div class="wrapper" id="main" data-track="x">
  <!-- promo banner -->
  <h1 style="color:red">Hello <span class="hl">world</span></h1>
  <p onclick="alert(1)">Some <b>bold</b> and <i>italic</i> text.</p>
  <a href="https://example.com" target="_blank" class="link">link</a>
  <scr` + `ipt>console.log('nope')</scr` + `ipt>
</div>`;

      $<HTMLButtonElement>('#load-sample').addEventListener('click', () => {
        input.value = SAMPLE;
        render();
      });

      updateModeCaption();
      render();
    </script>
  </body>
</html>
